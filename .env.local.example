# =============================================================================
# Doctor Kart — local environment template
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# =============================================================================

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role — server-side only. Used by webhook handlers and cron.
# DO NOT prefix with NEXT_PUBLIC_; it must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- Interakt (WhatsApp) ----------
# Used for appointment reminders today; will also drive patient OTP delivery
# once the WhatsApp OTP flow is built (see plans/supabase-infrastructure-setup.md).
INTERAKT_API_KEY=
INTERAKT_WEBHOOK_SECRET=
# Template name approved in Interakt console for patient sign-in OTP.
# Required only when the patient OTP API routes are wired up (Phase 6).
WA_OTP_TEMPLATE_NAME=patient_otp_v1
# Authentication-category template for the clinic ONBOARDING phone OTP (one
# {{1}} variable = the 6-digit code). Must be approved in Interakt/Meta.
ONBOARDING_WA_OTP_TEMPLATE=onboarding_otp_v1
# Synthetic-email suffix for phone-only auth.users rows created by the OTP flow.
OTP_AUTH_EMAIL_SUFFIX=otp.local

# ---------- SMTP (transactional email) ----------
# Used for the clinic onboarding EMAIL OTP. Leave SMTP_HOST unset in dev — the
# code is logged to the server console instead of emailed (works with MOCK_DATA,
# which also surfaces the code in the UI). Set all five in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Rxbooq <no-reply@rxbooq.com>

# ---------- Feature flags ----------
# When true, server-side data fetchers return canned demo data instead of
# hitting Supabase. Useful for UI iteration without a fully seeded DB.
# Set to false (or unset) to read from the live database.
MOCK_DATA=true

# ---------- Misc ----------
# A long random string used to authenticate the cron webhook hits from Supabase.
CRON_SECRET=change-me-to-a-long-random-string

# ---------- Public onboarding funnel ----------
# HMAC secret for the signed draft cookie that authorises wizard steps after
# the phone OTP gate. Must be 32+ chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Rotate to invalidate every in-flight onboarding draft.
ONBOARDING_DRAFT_SECRET=change-me-to-a-32-char-random-string

# SMS provider (reserved for future patient SMS). Onboarding OTP now goes over
# WhatsApp (phone) or SMTP email — not SMS. In dev with MOCK_DATA=true the real
# onboarding code is surfaced in the UI; verification always checks the real
# code (no bypass).
# SMS_PROVIDER=console

# ---------- Razorpay (subscriptions + upgrade flow) ----------
# Required for /admin/settings/billing upgrade and the webhook handler. Until
# these are set, the Free tier and trial flow still work end-to-end; only the
# explicit Upgrade button needs them.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional: GA4 + Google Business Profile API integration (Phase 2)
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_BUSINESS_PROFILE_ACCOUNT=
